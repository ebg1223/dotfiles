{
  "allowBackgroundProcesses": true,
  "autonomyLevel": "auto-medium",
  "awaitingInputSound": "fx-ack01",
  "cloudSessionSync": true,
  "commandAllowlist": [
    "ls",
    "pwd",
    "dir",
    "git status",
    "git diff",
    "git log",
    "git show",
    "git blame",
    "git ls-files"
  ],
  "commandDenylist": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf .",
    "rm -rf ~",
    "rm -rf ~/*",
    "rm -rf $HOME",
    "rm -r /",
    "rm -r /*",
    "rm -r ~",
    "rm -r ~/*",
    "mkfs",
    "mkfs.ext4",
    "mkfs.ext3",
    "mkfs.vfat",
    "mkfs.ntfs",
    "dd if=/dev/zero of=/dev",
    "dd of=/dev",
    "shutdown",
    "reboot",
    "halt",
    "poweroff",
    "init 0",
    "init 6",
    ":(){ :|: & };:",
    ":() { :|:& };:",
    "chmod -R 777 /",
    "chmod -R 000 /",
    "chown -R",
    "powershell Remove-Item -Recurse -Force",
    "Format-Volume",
    "format.com"
  ],
  "compactionModelMode": "current-model",
  "completionSound": "fx-ok01",
  "completionSoundFocusMode": "always",
  "customModels": [
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317/v1",
      "displayName": "$GPT-5.5",
      "extraArgs": {
        "service_tier": "priority"
      },
      "id": "custom:GPT-5.5",
      "index": 0,
      "model": "gpt-5.5",
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317",
      "displayName": "$Claude Opus 4.8",
      "id": "custom:Claude-Opus-4-8",
      "index": 1,
      "model": "claude-opus-4-8",
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317/v1",
      "displayName": "$Grok Composer 2.5 Fast",
      "id": "custom:Grok-Composer-2.5-Fast",
      "index": 2,
      "model": "grok-composer-2.5-fast",
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317/v1",
      "displayName": "$GLM 5.2",
      "id": "custom:GLM-5.2",
      "index": 3,
      "model": "glm-5.2",
      "noImageSupport": true,
      "provider": "openai"
    },
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317/v1",
      "displayName": "$Deepseek V4 Pro",
      "id": "custom:DeepSeek-V4-Pro",
      "index": 4,
      "model": "deepseek-v4-pro",
      "noImageSupport": true,
      "provider": "openai"
    },
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317/v1",
      "displayName": "$Deepseek V4 Flash",
      "id": "custom:DeepSeek-V4-Flash",
      "index": 5,
      "model": "deepseek-v4-flash",
      "noImageSupport": true,
      "provider": "openai"
    },
    {
      "apiKey": "CLI_PROXY_API_KEY",
      "baseUrl": "http://cliproxyapi:8317/v1",
      "displayName": "$Kimi K2.7 Code",
      "id": "custom:Kimi-K2.7-Code",
      "index": 6,
      "model": "kimi-k2.7-code",
      "noImageSupport": true,
      "provider": "openai"
    }
  ],
  "diffMode": "github",
  "dismissedNewModels": [
    "glm-5.2",
    "claude-opus-4-8",
    "kimi-k2.7-code",
    "minimax-m3"
  ],
  "enableCompletionBell": true,
  "enableCustomDroids": true,
  "enableDroidShield": false,
  "enableHooks": true,
  "enableReadinessReport": false,
  "enableSkills": true,
  "enableWarmup": true,
  "enabledPlugins": {
    "core@factory-plugins": true,
    "droid-control@factory-plugins": true
  },
  "extraKnownMarketplaces": {
    "agent-toolkit-for-aws": {
      "source": {
        "repo": "aws/agent-toolkit-for-aws",
        "source": "github"
      }
    }
  },
  "hasSeenMissionOnboarding": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "test ! -x '{{ .chezmoi.homeDir }}/.agents/hooks/session-start' || bash '{{ .chezmoi.homeDir }}/.agents/hooks/session-start' droid",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '{{ .chezmoi.homeDir }}/.factory/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh' ]; then /bin/sh '{{ .chezmoi.homeDir }}/.orca/agent-hooks/droid-hook.sh'; fi",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "ideActivationNudgedForVersion": {},
  "ideAutoConnect": false,
  "ideExtensionPromptedAt": {},
  "includeCoAuthoredByDroid": false,
  "logoAnimation": "off",
  "missionModelSettings": {
    "skipScrutiny": true,
    "validationWorkerModel": "custom:GPT-5.5",
    "validationWorkerReasoningEffort": "high",
    "workerModel": "custom:Grok-Composer-2.5-Fast"
  },
  "missionOrchestratorModel": "custom:Claude-Opus-4-8",
  "modelFavorites": [
    "glm-5.2",
    "custom:GPT-5.5",
    "custom:Grok-Composer-2.5-Fast",
    "custom:Claude-Opus-4-8",
    "custom:GLM-5.2"
  ],
  "sessionDefaultSettings": {
    "autonomyLevel": "medium",
    "autonomyMode": "auto-medium",
    "interactionMode": "auto",
    "model": "glm-5.2",
    "reasoningEffort": "high"
  },
  "showThinkingInMainView": true,
  "showTokenUsageIndicator": true,
  "soundFocusMode": "always",
  "specSaveEnabled": true,
  "terminalColorMode": "light",
  "theme": "factory-light",
  "todoDisplayMode": "pinned",
  "toolResultDisplay": "compact"
}
