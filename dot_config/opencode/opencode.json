{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@1.6.0"
  ],
  "model": "openai/gpt-5.5-fast",
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "disabled_providers": [],
  "provider": {
    "cliproxyapi": {
      "name": "CLI Proxy Anthropic",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://cliproxyapi:8317/v1",
        "apiKey": "cliproxy"
      },
      "models": {
        "claude-opus-4-8": {
          "name": "Claude Opus 4 8"
        },
        "grok-composer-2.5-fast": {
          "name": "Grok Composer 2.5 Fast"
        },
        "glm-5.2":{
          "name": "GLM 5.2"
        }
      }
    }
  },
  "shell": "/usr/bin/zsh",
  "agent": {
    "explore": {
      "model": "baseten/zai-org/GLM-5.2"
    },
    "orchestrator": {
      "permission": {
        "task": {
          "*": "deny",
          "explore": "allow",
          "general": "allow",
          "default-junior-engineer": "allow",
          "codex-junior-engineer": "allow",
          "glm-junior-engineer": "allow",
          "senior-engineer": "allow",
          "planner-reviewer": "allow",
          "second-opinion": "allow"
        }
      }
    }
  }
}
