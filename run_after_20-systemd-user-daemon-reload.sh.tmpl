#!/bin/sh
set -eu

{{- if and (eq .chezmoi.os "linux") .synara.enabled }}
if command -v systemctl >/dev/null 2>&1; then
  systemctl --user daemon-reload || {
    echo "Could not reload the systemd user manager. Run manually:"
    echo "  systemctl --user daemon-reload"
  }
fi
{{- else }}
:
{{- end }}
