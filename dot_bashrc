#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '
if [[ -d /ethan ]]; then
  export MISE_DATA_DIR=/ethan/data/mise
fi
export PATH="${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims:$PATH"
