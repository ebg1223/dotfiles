# Shared clipboard bindings.
# We write OSC52 directly to the active client TTY because tmux's native
# clipboard path is unreliable over mosh when several clients are attached.
# This template stays shared across macOS and Linux; the only rendered value is
# the absolute home directory for the helper path.

bind-key -T copy-mode Enter send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode y send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode M-w send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode C-w send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode DoubleClick1Pane select-pane \; send-keys -X select-word \; send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode TripleClick1Pane select-pane \; send-keys -X select-line \; send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"

bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode-vi C-j send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode-vi DoubleClick1Pane select-pane \; send-keys -X select-word \; send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
bind-key -T copy-mode-vi TripleClick1Pane select-pane \; send-keys -X select-line \; send-keys -X copy-pipe-and-cancel "{{ .chezmoi.homeDir }}/.local/bin/tmux-osc52-copy #{client_tty}"
