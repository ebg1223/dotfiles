{{- if eq .chezmoi.os "darwin" }}
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{- else if eq .chezmoi.os "linux" }}
if [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
{{- end }}

export PATH="$HOME/.local/bin:$PATH"

if [[ -d /ethan ]]; then
  export MISE_DATA_DIR=/ethan/data/mise
  export UV_CACHE_DIR=/ethan/cache/uv
fi

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# Runs after mise as zoxide is a mise installable package.
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# Runs last to capture all changes to shell from the previous commands.

# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

export POSH_THEME="rudolfs-light"
if command -v oh-my-posh >/dev/null 2>&1; then
  eval "$(oh-my-posh init zsh --config "$POSH_THEME")"
fi

# Customize to your needs...

# smux
export PATH="$HOME/.smux/bin:$PATH"

sesh-cc() {
  local session
  session="$(sesh list | fzf)"
  [ -z "$session" ] && return
  tmux -CC attach -t "$session" 2>/dev/null || tmux -CC new-session -A -s "$session"
}

synclaude() {
  : "${SYNTHETIC_AUTH_TOKEN:?Set SYNTHETIC_AUTH_TOKEN}"
  ANTHROPIC_BASE_URL=https://api.synthetic.new/anthropic \
  ANTHROPIC_AUTH_TOKEN="$SYNTHETIC_AUTH_TOKEN" \
  ANTHROPIC_DEFAULT_OPUS_MODEL=syn:large:text \
  ANTHROPIC_DEFAULT_SONNET_MODEL=syn:large:vision \
  ANTHROPIC_DEFAULT_HAIKU_MODEL=syn:small:text \
  CLAUDE_CODE_SUBAGENT_MODEL=syn:large:vision \
  CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
  CLAUDE_CODE_ATTRIBUTION_HEADER=0 \
  claude --dangerously-skip-permissions "$@"
}

cc() {
  claude --dangerously-skip-permissions "$@"
}

basetenclaude() {
  : "${BASETEN_API_KEY:?Set BASETEN_API_KEY}"
  ANTHROPIC_BASE_URL=https://inference.baseten.co \
  ANTHROPIC_AUTH_TOKEN="$BASETEN_API_KEY" \
  ANTHROPIC_DEFAULT_OPUS_MODEL=zai-org/GLM-5.2 \
  ANTHROPIC_DEFAULT_SONNET_MODEL=zai-org/GLM-5.2 \
  ANTHROPIC_DEFAULT_HAIKU_MODEL=zai-org/GLM-5.2 \
  CLAUDE_CODE_SUBAGENT_MODEL=zai-org/GLM-5.2 \
  CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
  CLAUDE_CODE_ATTRIBUTION_HEADER=0 \
  claude --dangerously-skip-permissions "$@"
}

fireworksclaude() {
  : "${FIREWORKS_API_KEY:?Set FIREWORKS_API_KEY}"
  ANTHROPIC_BASE_URL=https://api.fireworks.ai/inference \
  ANTHROPIC_AUTH_TOKEN="$FIREWORKS_API_KEY" \
  ANTHROPIC_DEFAULT_OPUS_MODEL=accounts/fireworks/models/glm-5p2 \
  ANTHROPIC_DEFAULT_SONNET_MODEL=accounts/fireworks/models/kimi-k2p7-code \
  ANTHROPIC_DEFAULT_HAIKU_MODEL=accounts/fireworks/models/deepseek-v4-flash \
  CLAUDE_CODE_SUBAGENT_MODEL=accounts/fireworks/models/deepseek-v4-flash \
  CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
  CLAUDE_CODE_ATTRIBUTION_HEADER=0 \
  claude --dangerously-skip-permissions "$@"
}
