{
  "lastChangelogVersion": "0.61.1",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "compaction": {
    "enabled": true
  },
  "theme": "light",
  "packages": [
    "npm:pi-interactive-shell",
    "npm:pi-extmgr",
    {
      "source": "npm:pi-subagents",
      "extensions": [
        "+index.ts",
        "+notify.ts"
      ]
    },
    "npm:pi-web-access",
    {
      "source": "npm:pi-amplike",
      "extensions": [
        "+extensions/modes.ts",
        "-extensions/subagent.ts"
      ]
    },
    "npm:@calesennett/pi-codex-fast",
    "npm:pi-tool-display",
    {
      "source": "npm:pi-notify",
      "extensions": [
        "+index.ts"
      ]
    },
    "git:github.com/ghoseb/pi-askuserquestion"
  ],
  "enabledModels": [
    "cerebras/zai-glm-4.7",
    "openai-codex/gpt-5.4"
  ],
  "pi-codex-fast": {
    "enabled": true
  }
}